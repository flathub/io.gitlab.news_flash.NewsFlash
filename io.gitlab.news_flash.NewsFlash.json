{
  "app-id": "io.gitlab.news_flash.NewsFlash",
  "runtime": "org.gnome.Platform",
  "runtime-version": "49",
  "sdk": "org.gnome.Sdk",
  "sdk-extensions": ["org.freedesktop.Sdk.Extension.rust-stable"],
  "add-extensions": {
    "com.github.rafostar.Clapper.Enhancers": {
      "version": "stable",
      "directory": "extensions/clapper/enhancers",
      "add-ld-path": "lib",
      "no-autodownload": false,
      "autodelete": false
    }
  },
  "command": "io.gitlab.news_flash.NewsFlash",
  "finish-args": [
    "--share=network",
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--socket=pulseaudio",
    "--device=dri",
    "--own-name=org.mpris.MediaPlayer2.Newsflash",
    "--env=CLAPPER_ENHANCERS_PATH=/app/extensions/clapper/enhancers/plugins",
    "--env=PYTHONPATH=/app/extensions/clapper/enhancers/python/site-packages"
  ],
  "build-options": {
    "append-path": "/usr/lib/sdk/rust-stable/bin",
    "env": {
      "CARGO_HOME": "/run/build/newsflash/cargo",
      "PASSWORD_CRYPT_KEY": "@PASSWORD_CRYPT_KEY@"
    },
    "arch": {
      "i386": {
        "env": {
          "LIBXML2": "/lib/i386-linux-gnu/libxml2.so"
        }
      },
      "arm": {
        "env": {
          "LIBXML2": "/lib/arm-linux-gnueabihf/libxml2.so"
        }
      },
      "x86_64": {
        "env": {
          "LIBXML2": "/lib/x86_64-linux-gnu/libxml2.so"
        }
      },
      "aarch64": {
        "env": {
          "LIBXML2": "/lib/aarch64-linux-gnu/libxml2.so"
        }
      }
    }
  },
  "modules": [
    "deno.json",
    "libpeas.json",
    "clapper.json",
    {
      "name": "newsflash",
      "buildsystem": "meson",
      "sources": [
        {
          "type": "archive",
          "url": "https://gitlab.com/api/v4/projects/8320003/packages/generic/newsflash/5.0.0/newsflash-5.0.0.tar.xz",
          "sha256": "ffc06988e3d9540c1606c9c82a5e0b612bd11e93960746d776a15d997837da67"
        }
      ]
    }
  ],
  "cleanup-commands": [
    "mkdir -p /app/lib/ffmpeg",
    "mkdir -p /app/extensions/clapper/enhancers"
  ]
}
