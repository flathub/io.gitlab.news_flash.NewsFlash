{
  "name": "clapper",
  "buildsystem": "meson",
  "config-opts": [
    "-Dclapper=enabled",
    "-Dclapper-gtk=enabled",
    "-Dclapper-app=disabled",
    "-Dintrospection=enabled",
    "-Dvapi=disabled"
  ],
  "cleanup": ["/include", "/lib/pkgconfig"],
  "sources": [
    {
      "type": "git",
      "url": "https://github.com/Rafostar/clapper.git",
      "tag": "0.10.0"
    }
  ]
}
